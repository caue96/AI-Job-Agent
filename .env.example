APP_ENV=development
POSTGRES_DB=jobagent
POSTGRES_USER=jobagent
POSTGRES_PASSWORD=
DATABASE_URL=sqlite:///./job_agent.db
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_REASONING_EFFORT=none
AI_GENERATION_MODE=mock
AI_MAX_RETRIES=1
AI_REQUEST_TIMEOUT_SECONDS=45
AI_MAX_OUTPUT_TOKENS=800
AI_MAX_JOB_DESCRIPTION_CHARS=12000
AI_FALLBACK_TO_MOCK=true
AI_INPUT_COST_PER_MILLION_USD=0
AI_CACHED_INPUT_COST_PER_MILLION_USD=0
AI_OUTPUT_COST_PER_MILLION_USD=0
CV_STORAGE_PATH=./data/cv_uploads
CV_MAX_UPLOAD_BYTES=10485760
CV_MAX_PAGES=40
CV_MIN_EXTRACTED_CHARACTERS=80
CV_RETENTION_DAYS=30
CV_UPLOADS_PER_MINUTE=10

# Job discovery runtime. Credentials remain server-side and are never stored in the database.
ITJOBS_API_KEY=
INFOJOBS_CLIENT_ID=
INFOJOBS_CLIENT_SECRET=
DISCOVERY_PROVIDER_TIMEOUT_SECONDS=15
DISCOVERY_MAX_PROVIDER_RESPONSE_BYTES=2000000
DISCOVERY_SCHEDULER_POLL_SECONDS=60
MATCHING_PERMITTED_COUNTRIES=ES,PT,IE
MATCHING_ALLOW_REMOTE=true
MATCHING_HARD_REJECT_MISSING_REQUIRED_SKILLS=false
MATCHING_HARD_REJECT_MISSING_LANGUAGE=true
MATCHING_HARD_REJECT_SALARY_BELOW_MIN=true
MATCHING_HARD_REJECT_OUTSIDE_LOCATION=true
MATCHING_HARD_REJECT_SENIORITY_GAP=true
MATCHING_HARD_REJECT_INCOMPATIBLE_WORK_AUTHORIZATION=true
MATCHING_SENIORITY_GAP_YEARS=2
